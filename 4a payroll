package com.example.labprogram4a; 
import android.os.Bundle;
import android.view.View; 
import android.widget.Button;
import android.widget.EditText;
import android.widget.TextView;


import androidx.appcompat.app.AppCompatActivity;


public class MainActivity extends AppCompatActivity {


EditText etname,etBasic; Button btnCalculate;
TextView tvHra, tvDa, tvPf, tvGross, tvNet;
 
@Override
protected void onCreate(Bundle savedInstanceState) { 
super.onCreate(savedInstanceState); 
setContentView(R.layout.activity_main);


etname = findViewById(R.id.etname);
etBasic = findViewById(R.id.etBasic);
btnCalculate = findViewById(R.id.btnCalculate);

tvHra = findViewById(R.id.tvHra); 
tvDa = findViewById(R.id.tvDa); 
tvPf = findViewById(R.id.tvPf);
tvGross = findViewById(R.id.tvGross);
tvNet = findViewById(R.id.tvNet);

btnCalculate.setOnClickListener(new View.OnClickListener() {
@Override
public void onClick(View view) {

double basic = Double.parseDouble(etBasic.getText().toString()); 
double hra = 0.1 * basic;
double da = 0.12 * basic; 
double pf = 0.15 * basic;

double gross = basic + hra + da; 
double net = gross - pf;

tvHra.setText("HRA: ₹ " + hra); 
tvDa.setText("DA: ₹ " + da); 
tvPf.setText("PF: ₹ " + pf);
tvGross.setText("Gross Salary: ₹ " + gross);
tvNet.setText("Net Salary: ₹ " + net)


}
});
}
}
 
